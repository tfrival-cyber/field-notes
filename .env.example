# Field Notes — environment variables
#
# Copy this file to `.env` and fill in anything you want to override:
#
#   cp .env.example .env
#
# Every variable here is OPTIONAL. Out of the box, Field Notes analyses images
# through your local `claude` CLI (Claude Code), so there is no key to set —
# if you're logged into Claude Code, it just works.


# ── Anthropic API key (optional) ─────────────────────────────────────────────
# Only needed if you DON'T have the `claude` CLI installed/logged in and want to
# fall back to the raw Anthropic API instead. Leave blank to use the CLI.
# Get one at: https://console.anthropic.com  (→ API keys → Create key)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Model override (optional) ────────────────────────────────────────────────
# Which Claude model to use for image analysis. Defaults to a current Sonnet.
# Example: claude-sonnet-4-6
# FIELD_NOTES_MODEL=


# ── Port (optional) ──────────────────────────────────────────────────────────
# The local port the server listens on. Defaults to 4317.
# PORT=4317


# ── Path to the claude CLI (optional) ────────────────────────────────────────
# The server auto-detects `claude` in the usual install locations. Set this only
# if yours lives somewhere unusual.
# CLAUDE_BIN=/Users/you/.local/bin/claude
